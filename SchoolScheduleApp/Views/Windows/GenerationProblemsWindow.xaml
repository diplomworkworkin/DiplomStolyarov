<Window x:Class="SchoolScheduleApp.Views.Windows.GenerationProblemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конфликты генерации"
        Width="860"
        Height="560"
        MinWidth="700"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="14"
            Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource AccentColor}"
            BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Конфликты автогенерации"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryText}"/>
                <TextBlock Text="Ниже показан полный список проблем, которые возникли при составлении расписания."
                           Margin="0,6,0,0"
                           Foreground="{DynamicResource SecondaryText}"/>
            </StackPanel>

            <Border Grid.Row="1"
                    CornerRadius="10"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    Padding="10">
                <ListBox x:Name="ProblemsList"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource PrimaryText}"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="#220FD5FF"
                                    BorderBrush="#330FD5FF"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryText}"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Width="160"
                        Margin="0,0,8,0"
                        Content="Скопировать всё"
                        Click="CopyAllButton_Click"/>
                <Button Width="100"
                        Content="Закрыть"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
