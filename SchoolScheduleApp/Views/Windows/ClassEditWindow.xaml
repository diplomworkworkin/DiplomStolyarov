<Window x:Class="SchoolScheduleApp.Views.Windows.ClassEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Класс" Width="430" SizeToContent="Height" MinHeight="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="15" Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource AccentColor}" BorderThickness="1">
        <Grid Margin="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                <TextBlock Text="Редактирование класса"
                           Foreground="{DynamicResource PrimaryText}"
                           FontSize="18" FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <!-- Название -->
                <TextBlock Text="Название (пример: 1-А, 11-Б):"
                           Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                <TextBox x:Name="TbClassName"
                         Text="{Binding AcademicClass.Name}"
                         Height="35" Padding="5"
                         Background="{DynamicResource InputBackground}"
                         Foreground="{DynamicResource PrimaryText}"
                         BorderBrush="{DynamicResource CardBorder}"/>

                <!-- Кол-во учеников -->
                <TextBlock Text="Количество учеников (1..30):"
                           Foreground="{DynamicResource SecondaryText}" Margin="0,15,0,5"/>
                <TextBox x:Name="TbStudentCount"
                         Text="{Binding AcademicClass.StudentCount}"
                         Height="35" Padding="5"
                         Background="{DynamicResource InputBackground}"
                         Foreground="{DynamicResource PrimaryText}"
                         BorderBrush="{DynamicResource CardBorder}"
                         PreviewTextInput="TbStudentCount_PreviewTextInput"
                         DataObject.Pasting="TbStudentCount_Pasting"/>

                <!-- Смена -->
                <TextBlock Text="Смена (1 или 2):"
                           Foreground="{DynamicResource SecondaryText}" Margin="0,15,0,5"/>
                <ComboBox SelectedValue="{Binding AcademicClass.Shift}"
                          SelectedValuePath="Tag"
                          Height="35">
                    
                    <ComboBoxItem Content="1 смена" Tag="1"/>
                    <ComboBoxItem Content="2 смена" Tag="2"/>
                </ComboBox>

                <!-- Куратор -->
                <TextBlock Text="Куратор (классный руководитель):"
                           Foreground="{DynamicResource SecondaryText}" Margin="0,15,0,5"/>

                <DockPanel>
                    <ComboBox ItemsSource="{Binding Teachers}"
                              DisplayMemberPath="FullName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding AcademicClass.CuratorTeacherId}"
                              Height="35"
                              DockPanel.Dock="Left"
                              Width="300"/>

                    <Button Content="Очистить"
                            Width="94" Margin="10,0,0,0"
                            Click="BtnClearCurator_Click"
                            Background="Transparent"
                            Foreground="{DynamicResource SecondaryText}"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </DockPanel>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                    <Button Content="Отмена" IsCancel="True" Click="BtnCancel_Click"
                            Background="Transparent" Foreground="{DynamicResource SecondaryText}"
                            BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>

                    <Button Content="Сохранить" IsDefault="True" Click="BtnSave_Click"
                            Background="{DynamicResource AccentColor}" Foreground="White"
                            FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand" Height="34">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
