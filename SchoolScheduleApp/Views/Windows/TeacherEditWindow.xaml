<Window x:Class="SchoolScheduleApp.Views.Windows.TeacherEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование"
        Width="520"
        SizeToContent="Height"
        MinHeight="360"
        MaxHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="15"
            Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource AccentColor}"
            BorderThickness="1">
        <Grid Margin="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Редактирование учителя"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="ФИО преподавателя:"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Teacher.FullName}"
                             Height="35"
                             Padding="8,0"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Text="Предмет:"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,15,0,5"/>
                    <ComboBox ItemsSource="{Binding Subjects}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding Teacher.SubjectId}"
                              Height="35"/>

                    <DockPanel Margin="0,10,0,0">
                        <TextBox x:Name="TbNewSubject"
                                 Width="300"
                                 Height="32"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Новый предмет"/>

                        <Button Content="+ Предмет"
                                Width="110"
                                Height="32"
                                Margin="10,0,0,0"
                                Background="Transparent"
                                Foreground="{DynamicResource AccentColor}"
                                BorderBrush="{DynamicResource AccentColor}"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="BtnAddSubject_Click"/>
                    </DockPanel>

                    <TextBlock Text="Закрепленный кабинет:"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,15,0,5"/>
                    <ComboBox ItemsSource="{Binding Classrooms}"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding Teacher.ClassroomId}"
                              Height="35">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Separator Margin="0,18,0,12" Opacity="0.4"/>

                    <TextBlock Text="Добавить кабинет (быстро):"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,0,0,8"/>

                    <DockPanel>
                        <TextBox x:Name="TbNewRoomNumber"
                                 Width="90"
                                 Height="32"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Номер кабинета"/>
                        <TextBox x:Name="TbNewRoomType"
                                 Width="150"
                                 Height="32"
                                 Margin="8,0,0,0"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Тип (необязательно)"/>
                        <TextBox x:Name="TbNewRoomCapacity"
                                 Width="90"
                                 Height="32"
                                 Margin="8,0,0,0"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Вместимость"/>

                        <Button Content="+ Кабинет"
                                Width="110"
                                Height="32"
                                Margin="10,0,0,0"
                                Background="Transparent"
                                Foreground="{DynamicResource AccentColor}"
                                BorderBrush="{DynamicResource AccentColor}"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="BtnAddClassroom_Click"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,30,0,0">
                        <Button Content="Отмена"
                                IsCancel="True"
                                Click="BtnCancel_Click"
                                Background="Transparent"
                                Foreground="{DynamicResource SecondaryText}"
                                BorderThickness="0"
                                Margin="0,0,10,0"
                                Cursor="Hand"/>

                        <Button Content="Сохранить"
                                IsDefault="True"
                                Click="BtnSave_Click"
                                Background="{DynamicResource AccentColor}"
                                Foreground="White"
                                FontWeight="Bold"
                                Padding="15,8"
                                BorderThickness="0"
                                Cursor="Hand"
                                Height="34"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
