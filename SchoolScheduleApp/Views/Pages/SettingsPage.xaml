<Page x:Class="SchoolScheduleApp.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SchoolScheduleApp.Views.Pages" xmlns:vm="clr-namespace:SchoolScheduleApp.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="SettingsPage">

    <Page.DataContext>
        <vm:SettingsViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Стиль для Toggle Switch (Переключатель) -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="50" Height="26">
                            <!-- Фон свитча (серый или акцентный) -->
                            <Border x:Name="Border" CornerRadius="13" 
                                    Background="{DynamicResource CardBorder}" 
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"/>
                            
                            <!-- Точка -->
                            <Ellipse x:Name="Dot" Width="20" Height="20" HorizontalAlignment="Left" Margin="3,0,0,0" Fill="White">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="Dot" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Dot" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для TextBox в настройках -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" 
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Настройки системы" Foreground="{DynamicResource PrimaryText}" FontSize="24" FontWeight="Bold" Margin="0,0,0,30"/>

        <!-- Контент настроек -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
            <StackPanel>

                <!-- БЛОК 1: ВНЕШНИЙ ВИД -->
                <Border Style="{StaticResource GlassCard}" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Внешний вид и Персонализация" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                        
                        <Grid Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Темная тема (Неон)" Foreground="{DynamicResource PrimaryText}" FontSize="14"/>
                                <TextBlock Text="Использовать темную тему оформления по умолчанию" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
                            </StackPanel>
                            <CheckBox Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right" IsChecked="{Binding IsDarkTheme}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- БЛОК 2: ПАРАМЕТРЫ РАСПИСАНИЯ -->
                <Border Style="{StaticResource GlassCard}" Padding="20" Margin="0,0,0,20"
                        Visibility="{Binding CanManageAcademicSettings, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Параметры учебного процесса" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Название учреждения:" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SchoolName}" Style="{StaticResource SettingsTextBox}"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Длительность урока (мин):" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding LessonDuration}" Style="{StaticResource SettingsTextBox}" Width="100" HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Длина перемены (мин):" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding BreakDuration}" Style="{StaticResource SettingsTextBox}" Width="100" HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Начало первого урока:" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding StartTime}" Style="{StaticResource SettingsTextBox}" Width="100" HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="API URL:" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ApiBaseUrl}"
                                     Style="{StaticResource SettingsTextBox}"
                                     ToolTip="Пример: http://127.0.0.1:8000 или https://api.school.ru"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- БЛОК 3: БЕЗОПАСНОСТЬ И ДАННЫЕ -->
                <Border Style="{StaticResource GlassCard}" Padding="20" Margin="0,0,0,20"
                        Visibility="{Binding CanManageAcademicSettings, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Подключение к API" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Проверка API" Foreground="{DynamicResource PrimaryText}" FontSize="14"/>
                                <TextBlock Text="Проверить доступность API по указанному адресу" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
                            </StackPanel>
                            <Button Content="Проверить API" Command="{Binding BackupCommand}"
                                    HorizontalAlignment="Right"
                                    Background="Transparent" Foreground="{DynamicResource AccentColor}" 
                                    BorderBrush="{DynamicResource AccentColor}" BorderThickness="1"
                                    Padding="15,8" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassCard}" Padding="20" Margin="0,0,0,20"
                        Visibility="{Binding CanExportSchedule, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Экспорт расписания" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Неделя для экспорта:"
                                       Foreground="{DynamicResource PrimaryText}"
                                       VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ExportWeekOptions}"
                                      SelectedItem="{Binding SelectedExportWeek}"
                                      DisplayMemberPath="Name"
                                      Height="34"
                                      HorizontalAlignment="Left"
                                      MinWidth="220"/>
                        </Grid>

                        <Grid Margin="0,0,0,12"
                              Visibility="{Binding IsTeacherRole, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Что экспортировать:"
                                       Foreground="{DynamicResource PrimaryText}"
                                       VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ExportScopeOptions}"
                                      SelectedItem="{Binding SelectedExportScope}"
                                      DisplayMemberPath="Name"
                                      Height="34"
                                      HorizontalAlignment="Left"
                                      MinWidth="260"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="📊 Excel (CSV)"
                                    Command="{Binding ExportCsvCommand}"
                                    Margin="0,0,12,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource AccentColor}"
                                    BorderBrush="{DynamicResource AccentColor}"
                                    BorderThickness="1"
                                    Padding="15,8"
                                    Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Content="📄 Word (.doc)"
                                    Command="{Binding ExportWordCommand}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource AccentColor}"
                                    BorderBrush="{DynamicResource AccentColor}"
                                    BorderThickness="1"
                                    Padding="15,8"
                                    Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- КНОПКА СОХРАНИТЬ -->
                <Button Content="💾 Сохранить изменения" Command="{Binding SaveCommand}"
                        HorizontalAlignment="Left" Margin="0,10,0,0"
                        Background="{DynamicResource AccentColor}" Foreground="White" FontWeight="Bold" FontSize="14"
                        Padding="30,12" BorderThickness="0" Cursor="Hand" Height="43">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
