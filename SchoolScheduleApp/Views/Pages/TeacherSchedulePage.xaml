<Page x:Class="SchoolScheduleApp.Views.Pages.TeacherSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:SchoolScheduleApp.ViewModels"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="TeacherSchedulePage">

    <Page.DataContext>
        <vm:TeacherScheduleViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Моё расписание"
                       Foreground="{DynamicResource PrimaryText}"
                       FontSize="24"
                       FontWeight="Bold"/>
            <TextBlock Text="Просмотр личного расписания учителя"
                       Foreground="{DynamicResource SecondaryText}"
                       FontSize="12"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,0">
                    <TextBlock Text="День недели" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding DayOptions}"
                              SelectedItem="{Binding SelectedDay}"
                              DisplayMemberPath="Name"
                              Height="34"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,12,0">
                    <TextBlock Text="Неделя" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding WeekOptions}"
                              SelectedItem="{Binding SelectedWeek}"
                              DisplayMemberPath="Name"
                              Height="34"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,12,0">
                    <TextBlock Text="Класс" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding ClassOptions}"
                              SelectedItem="{Binding SelectedClass}"
                              DisplayMemberPath="Name"
                              Height="34"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Grid.Row="0" Margin="0,0,12,0">
                    <TextBlock Text="Предмет" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding SubjectOptions}"
                              SelectedItem="{Binding SelectedSubject}"
                              DisplayMemberPath="Name"
                              Height="34"/>
                </StackPanel>

                <Button Grid.Column="4" Grid.Row="0"
                        Content="Сброс"
                        Command="{Binding ResetFiltersCommand}"
                        Margin="0,18,0,0"
                        Padding="12,6"
                        Background="{DynamicResource CardBorder}"
                        Foreground="{DynamicResource PrimaryText}"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <StackPanel Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
                    <TextBlock Text="Неделя:" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
                    <TextBlock Text="{Binding WeekRangeText}" Foreground="{DynamicResource PrimaryText}" FontSize="12" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding ErrorMessage}" Foreground="#ff6b6b" FontWeight="Bold" Margin="0,0,0,10"/>

            <DataGrid x:Name="ScheduleGrid"
                      Grid.Row="1"
                      Style="{StaticResource WowDataGrid}"
                      ItemsSource="{Binding ScheduleRows}"
                      LoadingRow="ScheduleGrid_LoadingRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="День" Binding="{Binding Day}" Width="150"/>
                    <DataGridTextColumn Header="Время" Binding="{Binding TimeRange}" Width="140"/>
                    <DataGridTextColumn Header="Класс" Binding="{Binding AcademicClass}" Width="120"/>
                    <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="*"/>
                    <DataGridTextColumn Header="Кабинет" Binding="{Binding Classroom}" Width="110"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
