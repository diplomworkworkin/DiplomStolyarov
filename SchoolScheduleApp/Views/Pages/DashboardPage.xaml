<Page x:Class="SchoolScheduleApp.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SchoolScheduleApp.Views.Pages" xmlns:vm="clr-namespace:SchoolScheduleApp.ViewModels"
     mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="DashboardPage">

    <Page.DataContext>
        <vm:AdminViewModel/>
    </Page.DataContext>

    <Grid Margin="40,0,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Ряд Карточек -->
        <UniformGrid Columns="3" Grid.Row="0" Margin="0,0,0,30">

            <!-- 1. Учителя (ИСПРАВЛЕНО) -->
            <Border Style="{StaticResource GlassCard}" Margin="0,0,20,0" Height="160">
                <Grid>
                    <Ellipse Width="80" Height="80" HorizontalAlignment="Right" VerticalAlignment="Top" 
                             Margin="0,15,15,0" Fill="#2000d2ff"/>
                    <StackPanel VerticalAlignment="Center" Margin="25,0,0,0">
                        <Border Width="45" Height="45" CornerRadius="12" Background="#2000d2ff" 
                                HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="👨‍🏫" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22"/>
                        </Border>

                        <TextBlock Text="{Binding TeachersCount}" FontSize="36" FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,5"/>
                        <TextBlock Text="Всего учителей" 
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Классы (ИСПРАВЛЕНО) -->
            <Border Style="{StaticResource GlassCard}" Margin="0,0,20,0" Height="160">
                <Grid>
                    <Ellipse Width="80" Height="80" HorizontalAlignment="Right" VerticalAlignment="Top" 
                             Margin="0,15,15,0" Fill="#20bd00ff"/>
                    <StackPanel VerticalAlignment="Center" Margin="25,0,0,0">
                        <Border Width="45" Height="45" CornerRadius="12" Background="#20bd00ff" 
                                HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="🎓" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22"/>
                        </Border>

                        <TextBlock Text="{Binding StudentsCount}" FontSize="36" FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,5"/>
                        <TextBlock Text="Всего классов" 
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. Статус (ИСПРАВЛЕНО) -->
            <Border Style="{StaticResource GlassCard}" Height="160">
                <Grid>
                    <Ellipse Width="80" Height="80" HorizontalAlignment="Right" VerticalAlignment="Top" 
                             Margin="0,15,15,0" Fill="#2000ff9d"/>
                    <StackPanel VerticalAlignment="Center" Margin="25,0,0,0">
                        <Border Width="45" Height="45" CornerRadius="12" Background="#2000ff9d" 
                                HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="📊" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22"/>
                        </Border>
                        <TextBlock Text="{Binding ScheduleStatus}" FontSize="24" FontWeight="Bold" 
                                   Foreground="{Binding ScheduleStatusBrush}" Margin="0,0,0,5"/>

                        <TextBlock Text="Статус расписания" 
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- График загруженности (в %) -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Шапка -->
                <DockPanel Grid.Row="0" Margin="25,12,25,0">
                    <TextBlock Text="Аналитика загруженности аудиторий" 
                               Foreground="{DynamicResource PrimaryText}" FontSize="16" FontWeight="Bold"
                               DockPanel.Dock="Left"/>
                </DockPanel>

                <Grid Grid.Row="1" Margin="20,6,20,20">
                    <Viewbox Stretch="Uniform">
                        <Canvas Width="800" Height="250">
                            <TextBlock Canvas.Left="4" Canvas.Top="12"
                                       Text="{Binding RoomLoadYAxisTopText}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       FontSize="10"/>
                            <TextBlock Canvas.Left="4" Canvas.Top="102"
                                       Text="{Binding RoomLoadYAxisMiddleText}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       FontSize="10"/>
                            <TextBlock Canvas.Left="4" Canvas.Top="192"
                                       Text="{Binding RoomLoadYAxisBottomText}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       FontSize="10"/>

                            <TextBlock Canvas.Left="38" Canvas.Top="2"
                                       Text="Загрузка, %"
                                       Foreground="{DynamicResource SecondaryText}"
                                       FontSize="10"
                                       FontWeight="SemiBold"/>

                            <Line X1="70" Y1="20" X2="780" Y2="20" Stroke="#40808080" StrokeThickness="1" StrokeDashArray="4 4"/>
                            <Line X1="70" Y1="110" X2="780" Y2="110" Stroke="#40808080" StrokeThickness="1" StrokeDashArray="4 4"/>
                            <Line X1="70" Y1="200" X2="780" Y2="200" Stroke="#40808080" StrokeThickness="1" StrokeDashArray="4 4"/>
                            <Line X1="70" Y1="20" X2="70" Y2="200" Stroke="#40808080" StrokeThickness="1"/>

                            <!-- Заливка под линией -->
                            <Polygon Points="{Binding RoomLoadArea}"
                                     Fill="#1000d2ff"/>

                            <!-- Линия -->
                            <Polyline Points="{Binding RoomLoadLine}"
                                      Stroke="#00d2ff" StrokeThickness="3">
                                <Polyline.Effect>
                                    <DropShadowEffect Color="#00d2ff" BlurRadius="15" ShadowDepth="0"/>
                                </Polyline.Effect>
                            </Polyline>

                            <TextBlock Canvas.Left="36" Canvas.Top="214" Width="70" TextAlignment="Center"
                                       Text="Пн" Foreground="{DynamicResource SecondaryText}" FontSize="10"/>
                            <TextBlock Canvas.Left="212" Canvas.Top="214" Width="70" TextAlignment="Center"
                                       Text="Вт" Foreground="{DynamicResource SecondaryText}" FontSize="10"/>
                            <TextBlock Canvas.Left="390" Canvas.Top="214" Width="70" TextAlignment="Center"
                                       Text="Ср" Foreground="{DynamicResource SecondaryText}" FontSize="10"/>
                            <TextBlock Canvas.Left="568" Canvas.Top="214" Width="70" TextAlignment="Center"
                                       Text="Чт" Foreground="{DynamicResource SecondaryText}" FontSize="10"/>
                            <TextBlock Canvas.Left="744" Canvas.Top="214" Width="70" TextAlignment="Center"
                                       Text="Пт" Foreground="{DynamicResource SecondaryText}" FontSize="10"/>
                            <TextBlock Canvas.Left="380" Canvas.Top="232"
                                       Text="Дни недели"
                                       Foreground="{DynamicResource SecondaryText}"
                                       FontSize="10"
                                       FontWeight="SemiBold"/>
                        </Canvas>
                    </Viewbox>

                    <!-- Кнопка обновления + легенда справа сверху -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-35,0,0">
                        <Button Content="↻"
                                Width="43"
                                Height="30"
                                Margin="100,0,-25,5"
                                HorizontalAlignment="Center"
                                Command="{Binding RefreshRoomLoadCommand}"
                                Background="Transparent"
                                Foreground="{DynamicResource AccentColor}"
                                BorderBrush="{DynamicResource AccentColor}"
                                BorderThickness="1"
                                Cursor="Hand"
                                ToolTip="Обновить график">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Border Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,6"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="#00d2ff" Margin="0,0,6,0"/>
                                    <TextBlock Text="Загрузка (среднее): " Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
                                    <TextBlock Text="{Binding RoomLoadPercentText}" Foreground="{DynamicResource PrimaryText}" FontSize="12" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Text="{Binding RoomLoadRangeText}" Foreground="{DynamicResource SecondaryText}" FontSize="11" Margin="16,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
