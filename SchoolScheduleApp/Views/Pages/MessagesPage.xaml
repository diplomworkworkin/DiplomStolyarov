<Page x:Class="SchoolScheduleApp.Views.Pages.MessagesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:SchoolScheduleApp.ViewModels"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1200"
      Title="MessagesPage">

    <Page.DataContext>
        <vm:MessagesViewModel/>
    </Page.DataContext>

    <Grid Margin="30,0,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Сообщения"
                       VerticalAlignment="Center"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"/>

            <Button Grid.Column="1"
                    Width="42"
                    Height="30"
                    Margin="0,0,8,0"
                    Command="{Binding RefreshCommand}"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    Cursor="Hand"
                    ToolTip="Обновить">
                <TextBlock Text="↻"
                           FontSize="15"
                           Foreground="{DynamicResource AccentColor}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>

            <Button Grid.Column="2"
                    Content="Обратиться к администратору"
                    Visibility="{Binding IsTeacher, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Command="{Binding ToggleComposerCommand}"
                    HorizontalAlignment="Right"
                    Background="{DynamicResource AccentColor}"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12,7"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="14,12"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Диалоги"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryText}"/>

                            <Button Grid.Column="1"
                                    Height="28"
                                    Command="{Binding ClearConversationsCommand}"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    ToolTip="Очистить диалоги">
                                <TextBlock Text="🗑"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryText}"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Conversations}"
                             SelectedItem="{Binding SelectedConversation}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource PrimaryText}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8,6"
                                        Padding="10"
                                        CornerRadius="10"
                                        BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1"
                                        Background="{DynamicResource InputBackground}">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Header}" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                            <TextBlock Text="{Binding UpdatedAtText}" FontSize="11" Foreground="{DynamicResource SecondaryText}" DockPanel.Dock="Right"/>
                                        </DockPanel>

                                        <TextBlock Margin="0,4,0,0" Text="{Binding CategoryText}" FontSize="12" Foreground="{DynamicResource AccentColor}"/>
                                        <TextBlock Margin="0,2,0,0" Text="{Binding ReplacementModeText}" FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
                                        <TextBlock Margin="0,4,0,0" Text="{Binding LastMessagePreview}" Foreground="{DynamicResource SecondaryText}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Margin="0,4,0,0" Text="{Binding StatusText}" FontSize="12" FontWeight="Bold" Foreground="{Binding StatusBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource GlassCard}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="14,12"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedConversation.Header, TargetNullValue=Выберите диалог}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryText}"/>

                            <WrapPanel Margin="0,5,0,0">
                                <TextBlock Margin="0,0,12,0" Text="{Binding SelectedConversation.CategoryText}" Foreground="{DynamicResource AccentColor}"/>
                                <TextBlock Margin="0,0,12,0" Text="{Binding SelectedConversation.ReplacementModeText}" Foreground="{DynamicResource SecondaryText}"/>
                                <TextBlock Text="{Binding SelectedConversation.StatusText}" FontWeight="Bold" Foreground="{Binding SelectedConversation.StatusBrush}"/>
                            </WrapPanel>

                            <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource SecondaryText}">
                                <Run Text="Класс: "/><Run Text="{Binding SelectedConversation.TargetClassName, TargetNullValue=—}"/>
                                <Run Text=", день: "/><Run Text="{Binding SelectedConversation.TargetDayOfWeek, TargetNullValue=—}"/>
                                <Run Text=", урок: "/><Run Text="{Binding SelectedConversation.TargetLessonIndex, TargetNullValue=—}"/>
                                <Run Text=", замещает: "/><Run Text="{Binding SelectedConversation.ReplacementTeacherName, TargetNullValue=—}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ChatMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MaxWidth="560"
                                            Margin="12,8,12,0"
                                            Padding="12"
                                            HorizontalAlignment="{Binding Alignment}"
                                            Background="{Binding BubbleBackground}"
                                            CornerRadius="12"
                                            Opacity="0">
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="{Binding BubbleForeground}"/>
                                            <TextBlock Margin="0,6,0,0" Text="{Binding Meta}" FontSize="11" Foreground="#CCFFFFFF"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2"
                          Margin="12"
                          Visibility="{Binding CanSendInChat, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="38"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Grid.Column="2"
                                Content="Отправить"
                                Command="{Binding SendChatMessageCommand}"
                                Background="{DynamicResource AccentColor}"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Cursor="Hand"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.ColumnSpan="3"
                    Background="#90000000"
                    Visibility="{Binding IsComposerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Width="760" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Style="{StaticResource GlassCard}" Padding="20" CornerRadius="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="3"
                                       Margin="0,0,0,12"
                                       Text="Новая заявка администратору"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryText}"/>

                            <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,10,10"
                                      ItemsSource="{Binding Categories}"
                                      DisplayMemberPath="Title"
                                      SelectedItem="{Binding SelectedCategoryOption}"/>

                            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,10,10"
                                      Visibility="{Binding IsLessonReplacementSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      ItemsSource="{Binding ReplacementModes}"
                                      DisplayMemberPath="Title"
                                      SelectedItem="{Binding SelectedReplacementModeOption}"/>

                            <ComboBox Grid.Row="1" Grid.Column="2" Margin="0,0,0,10"
                                      Visibility="{Binding IsLessonReplacementSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      ItemsSource="{Binding Days}"
                                      DisplayMemberPath="Title"
                                      SelectedItem="{Binding SelectedDayOption}"/>

                            <ComboBox Grid.Row="2" Grid.Column="0" Margin="0,0,10,10"
                                      Visibility="{Binding IsLessonReplacementSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      ItemsSource="{Binding TeacherClasses}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedClassOption}"/>

                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,10,10"
                                      Visibility="{Binding IsReplaceByOtherTeacher, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      ItemsSource="{Binding ReplacementTeachers}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedReplacementTeacherOption}"/>

                            <ComboBox Grid.Row="2" Grid.Column="2" Margin="0,0,0,10"
                                      Visibility="{Binding IsLessonReplacementSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding LessonIndex}">
                                <ComboBoxItem Content="1 урок" Tag="1"/>
                                <ComboBoxItem Content="2 урок" Tag="2"/>
                                <ComboBoxItem Content="3 урок" Tag="3"/>
                                <ComboBoxItem Content="4 урок" Tag="4"/>
                                <ComboBoxItem Content="5 урок" Tag="5"/>
                                <ComboBoxItem Content="6 урок" Tag="6"/>
                                <ComboBoxItem Content="7 урок" Tag="7"/>
                                <ComboBoxItem Content="8 урок" Tag="8"/>
                            </ComboBox>

                            <TextBox Grid.Row="3"
                                     Grid.ColumnSpan="3"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding NewRequestMessage, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="4"
                                       Grid.ColumnSpan="3"
                                       Margin="0,0,0,12"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Text="Для замены урока: выберите режим, день, класс и номер урока. Если выбран режим «Заменить мой урок», укажите заменяющего учителя."/>

                            <StackPanel Grid.Row="5" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Отмена"
                                        Margin="0,0,10,0"
                                        Command="{Binding ToggleComposerCommand}"
                                        Background="Transparent"
                                        Foreground="{DynamicResource SecondaryText}"
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                                <Button Content="Создать чат-заявку"
                                        Command="{Binding CreateRequestCommand}"
                                        Background="{DynamicResource AccentColor}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="14,8"
                                        FontWeight="Bold"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2"
                        Margin="0,12,12,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Orientation="Horizontal"
                        Visibility="{Binding CanModerate, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Content="Принять заявку"
                        Command="{Binding ApproveCommand}"
                        Background="#2e7d32"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="10,6"
                        FontSize="13"
                        Margin="0,0,8,0"
                        Cursor="Hand"/>
                <Button Content="Отклонить заявку"
                        Command="{Binding RejectCommand}"
                        Background="#c62828"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="10,6"
                        FontSize="13"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
