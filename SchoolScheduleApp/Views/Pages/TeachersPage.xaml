<Page x:Class="SchoolScheduleApp.Views.Pages.TeachersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SchoolScheduleApp.Views.Pages" xmlns:vm="clr-namespace:SchoolScheduleApp.ViewModels"
       mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="TeachersPage">

    <Page.DataContext>
        <vm:TeachersViewModel/>
    </Page.DataContext>

    <Grid Margin="40,0,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Управление персоналом" Foreground="{DynamicResource PrimaryText}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="+ Добавить учителя" Command="{Binding AddCommand}" HorizontalAlignment="Right"
                    Background="{DynamicResource AccentColor}" Foreground="White" FontWeight="Bold" FontSize="14"
                    Padding="14,7" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </DockPanel>

        <Border Style="{StaticResource GlassCard}" Grid.Row="1" Padding="0">

            <DataGrid ItemsSource="{Binding TeachersList}"
                      IsReadOnly="True"
                      Background="Transparent" BorderThickness="0" 
                      HeadersVisibility="Column" 
                      GridLinesVisibility="All" 
                      HorizontalGridLinesBrush="{DynamicResource CardBorder}" 
                      VerticalGridLinesBrush="{DynamicResource CardBorder}"
                      RowBackground="Transparent" 
                      AlternatingRowBackground="{DynamicResource HoverBackground}"
                      Foreground="{DynamicResource PrimaryText}"
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      RowHeight="45" ColumnHeaderHeight="45"
                      PreviewMouseDown="NonInteractiveGrid_PreviewMouseDown"
                      PreviewKeyDown="NonInteractiveGrid_PreviewKeyDown">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource CardBorder}"/>
                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="Padding" Value="15,0,0,0"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>

                    <Style TargetType="DataGridCell">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="15,0,0,0" Background="Transparent">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <!-- ИСПРАВЛЕНО: Цвет текста берется из темы -->
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SelectedText}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="ФИО Преподавателя" Binding="{Binding FullName}" Width="*"/>

                    <!-- Предмет учителя (через навигационное свойство) -->
                    <DataGridTextColumn Header="Предмет" Binding="{Binding SubjectName}" Width="220"/>

                    <DataGridTemplateColumn Header="Статус" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="5" Padding="10,2" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#20FF4D4D"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#2000FF9D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FF4D4D"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="#00FF9D"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Действия" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✎" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                           CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource AccentColor}" BorderThickness="0" 
                                            Cursor="Hand" Margin="0,0,15,0" FontSize="16"/>
                                    <Button Content="✕" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                            CommandParameter="{Binding}"  Background="Transparent" Foreground="#ff4d4d" BorderThickness="0" 
                                            Cursor="Hand" FontSize="16"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>