<Window x:Class="SchoolScheduleApp.Views.TeacherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SchoolScheduleApp.ViewModels"
        mc:Ignorable="d"
        Title="Панель Учителя" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:TeacherShellViewModel/>
    </Window.DataContext>

    <Border Background="{DynamicResource WindowBackground}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="20"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                        <Setter Property="CornerRadius" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                    CornerRadius="20,0,0,20" BorderBrush="{DynamicResource SidebarBorder}" BorderThickness="0,0,1,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="30,40,0,50">
                        <Border Width="40" Height="40" CornerRadius="20" BorderBrush="{DynamicResource AccentColor}" BorderThickness="2">
                            <TextBlock Text="📘" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"
                                       Foreground="{DynamicResource PrimaryText}"/>
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource LogoGlowColor}" BlurRadius="10" ShadowDepth="0"/>
                            </Border.Effect>
                        </Border>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="МБОУ СШ №11" Foreground="{DynamicResource PrimaryText}" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="Кабинет учителя" Foreground="{DynamicResource AccentColor}" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="МОЁ РАСПИСАНИЕ" Foreground="{DynamicResource SecondaryText}" FontSize="10" Margin="30,0,0,10" FontWeight="Bold"/>
                    <Button Content="📅   Моё расписание" Style="{StaticResource MenuButton}" Click="BtnSchedule_Click"/>
                    <Button x:Name="BtnCuratorClassSchedule"
                            Content="🏫   Расписание курируемого класса"
                            Style="{StaticResource MenuButton}"
                            Click="BtnCuratorClassSchedule_Click"
                            Visibility="Collapsed"/>
                    <Button x:Name="BtnMessages" Content="✉️   Сообщения" Style="{StaticResource MenuButton}" Click="BtnMessages_Click"/>

                    <TextBlock Text="СИСТЕМА" Foreground="{DynamicResource SecondaryText}" FontSize="10" Margin="30,30,0,10" FontWeight="Bold"/>
                    <Button Content="⚙️   Настройки" Style="{StaticResource MenuButton}" Click="BtnSettings_Click"/>
                    <Button Content="🚪   Выйти" Style="{StaticResource MenuButton}" Margin="0,50,0,0" Click="BtnLogout_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock x:Name="PageTitle" Text="Моё расписание" VerticalAlignment="Center" Margin="40,0,0,0"
                               Foreground="{DynamicResource PrimaryText}" FontSize="24" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="20" Padding="15,5,15,5" Margin="0,0,20,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Ellipse Width="35" Height="35">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="pack://application:,,,/Assets/teacher.png" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </StackPanel>
                        </Border>
                        <Button Content="−" Width="45" Height="40" Background="Transparent" Foreground="{DynamicResource SecondaryText}" FontSize="20" BorderThickness="0"
                                Cursor="Hand" Click="BtnMinimize_Click"/>
                        <Button Content="▢" Width="45" Height="40" Background="Transparent" Foreground="{DynamicResource SecondaryText}" FontSize="15" BorderThickness="0"
                                Cursor="Hand" Click="BtnMaximize_Click"/>
                        <Button Content="✕" Width="48" Height="40" Background="Transparent" Foreground="{DynamicResource SecondaryText}" FontSize="18" BorderThickness="0"
                                Cursor="Hand" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>

                <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
            </Grid>
        </Grid>
    </Border>
</Window>
